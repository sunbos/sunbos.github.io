// 1. 视觉优化与圆角修补
// 大部分基础圆角（如卡片、侧边栏）已遵循 NexT 规范，由 variables.styl 中的 $border-radius 变量自动接管。
// 这里仅针对 Gemini 主题特有的“上下拼接”结构（头部Logo区与底部菜单区）进行缝合并统一阴影。

.post-block,
.sidebar-inner,
.comments,
.search-popup {
  box-shadow: 0 4px 15px rgba(0,0,0,0.05) !important;
}

// 缝合头部拼接区域
.site-brand-container {
  border-radius: 15px 15px 0 0 !important;
}
.site-nav {
  border-radius: 0 0 15px 15px !important;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05) !important;
}
.site-nav .menu {
  border-radius: 0 0 15px 15px !important;
}

// 消除容器直角，但保留组件内部配色
.header,
.column {
  background: transparent !important;
  box-shadow: none !important;
}
.site-nav {
  // 亮色下菜单栏保持白底以确保按钮对比度
  background: var(--content-bg-color) !important;
}

// 2. 彻底禁用头像旋转
.site-author-image {
  animation: none !important;
  transition: transform 0.3s ease-out !important;
  &:hover {
    transform: scale(1.1) !important;
  }
}

// 3. 【统一底部配色】消除区域偏差
.footer {
  background: transparent !important;
  color: var(--text-color) !important;
}
.footer-inner {
  background: transparent !important; 
  box-shadow: none !important;
}

// 4. 【高性能暗黑模式】变量集
:root[data-theme="dark"] {
  --body-bg-color: #1a1a1a;
  --content-bg-color: #242424;
  --card-bg-color: #242424;
  --text-color: #ddd;
  --link-color: #88d;
  --link-hover-color: #aaf;
  --brand-color: #ddd;
  --blockquote-color: #999;
  --btn-default-bg: #333;
  --btn-default-color: #eee;
  --btn-default-border-color: #444;
  --menu-item-bg-color: #333;
  
  body {
    background: #1a1a1a !important;
    color: #ddd !important;
  }
  
  .main-inner, .sidebar-inner, .post-block, .site-brand-container, .site-nav, .search-popup {
    background: #242424 !important;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4) !important;
  }
  
  .site-title, .site-author-name, .menu-item a, .site-subtitle {
    color: #eee !important;
  }

  // 强化激活/暗黑菜单对比度
  .menu-item .menu-item-active a, .menu-item a:hover {
    background: #333 !important;
    color: #fff !important;
  }
  
  canvas {
    opacity: 0.8;
  }
}
