// 1. 视觉优化与圆角修补
// 强制将各个主要容器应用 15px 圆角和柔和阴影，
// 且去除了之前容易引发副作用的全局 overflow 隐藏限制，以确保子组件正常渲染。

.post-block,
.sidebar-inner,
.comments,
.pagination,
.search-popup {
  border-radius: 15px !important;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05) !important;
}

// 缝合头部拼接区域
.site-brand-container {
  border-radius: 15px 15px 0 0 !important;
}
.site-nav {
  border-radius: 0 0 15px 15px !important;
  box-shadow: 0 4px 15px rgba(0,0,0,0.05) !important;
}
.site-nav .menu {
  border-radius: 0 0 15px 15px !important;
}

// 消除容器直角，但保留组件内部配色
.header,
.column {
  background: transparent !important;
  box-shadow: none !important;
}
.site-nav {
  // 亮色下菜单栏保持白底以确保按钮对比度
  background: var(--content-bg-color) !important;
}

// 2. 彻底禁用头像旋转
.site-author-image {
  animation: none !important;
  transition: transform 0.3s ease-out !important;
  &:hover {
    transform: scale(1.1) !important;
  }
}

// 3. 【统一底部配色】消除区域偏差
.footer {
  background: transparent !important;
  color: var(--text-color) !important;
}
.footer-inner {
  background: transparent !important; 
  box-shadow: none !important;
}

// 5. 强化导航菜单选中与悬停状态 (高对比度设计)
.menu-item-active a, .menu-item a:hover {
  background: #333 !important; /* 亮色模式下直接使用深黑底色反转 */
  color: #fff !important;      /* 文字纯白 */
  border-radius: 8px !important;
  font-weight: 600 !important; /* 文字加粗 */
  box-shadow: 0 2px 6px rgba(0,0,0,0.2) !important; /* 增加微悬浮感 */
}

// 隐藏原生那颗容易被忽略的小灰点
.main-menu .menu-item-active::after {
  display: none !important;
}

// 4. 【高性能暗黑模式】变量集
:root[data-theme="dark"] {
  --body-bg-color: #1a1a1a;
  --content-bg-color: #242424;
  --card-bg-color: #242424;
  --text-color: #ddd;
  --link-color: #88d;
  --link-hover-color: #aaf;
  --brand-color: #ddd;
  --blockquote-color: #999;
  --btn-default-bg: #333;
  --btn-default-color: #eee;
  --btn-default-border-color: #444;
  --menu-item-bg-color: #333;
  
  body {
    background: #1a1a1a !important;
    color: #ddd !important;
  }
  
  .sidebar-inner, .post-block, .site-brand-container, .site-nav, .search-popup, .comments, .pagination {
    background: #242424 !important;
    box-shadow: 0 4px 20px rgba(0,0,0,0.4) !important;
  }
  
  .site-title, .site-author-name, .menu-item a, .site-subtitle {
    color: #eee !important;
  }

  // 强化激活/暗黑菜单对比度 (高对比度反转设计)
  .menu-item-active a, .menu-item a:hover {
    background: #e5e5e5 !important; /* 暗色模式下使用非常显眼的亮灰色 */
    color: #222 !important;         /* 文字变成深黑 */
    font-weight: 600 !important;
    box-shadow: 0 2px 6px rgba(255,255,255,0.1) !important;
  }
  
  canvas {
    opacity: 0.8;
  }
}
