// ==========================================
// 终极“特权级”样式深度对齐与性能方案
// ==========================================

// 1. 强制圆角：针对 Gemini 高版本对直角的顽固设置进行全面“打磨”
.post-block,
.main-inner,
.header-inner,
.sidebar-inner,
.sidebar,
.comments,
.pagination,
.footer-inner,
.widget-wrap {
  border-radius: 15px !important;
  overflow: hidden !important; // 确保内部图片/色块不会溢出圆角
}

// 侧边栏整体在某些分辨率下会有直角容器，这里一并修掉
.column {
  border-radius: 15px !important;
}

// 2. 彻底禁用头像旋转（物理禁掉属性）
.site-author-image {
  animation: none !important;
  transition: transform 0.3s ease-out !important;
  &:hover {
    transform: scale(1.1) !important; // 只保留缩放，按你喜欢的固定感
  }
}

// 3. 【高性能暗黑模式】变量集：不再使用滤镜，而是直接重载配色
[data-theme="dark"] {
  --body-bg-color: #1a1a1a;
  --content-bg-color: #242424;
  --card-bg-color: #242424;
  --text-color: #ddd;
  --link-color: #88d;
  --link-hover-color: #aaf;
  --brand-color: #ddd;
  --blockquote-color: #999;
  --btn-default-bg: #333;
  --btn-default-color: #eee;
  --btn-default-border-color: #444;
  
  // 核心背景覆盖
  body {
    background: #1a1a1a !important;
    color: #ddd !important;
  }
  
  .header, .main-inner, .sidebar-inner, .post-block, .footer {
    background: #242424 !important;
  }
  
  // 修正那些在暗色下太亮的组件
  .site-title, .site-author-name, .menu-item a {
    color: #eee !important;
  }
  
  // 给 canvas 降低一些对比度
  canvas {
    opacity: 0.8;
  }
}
