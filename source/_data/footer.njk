<!-- 网站运行时间 -->
<div class="run-time" style="margin-top: 10px; font-size: 13px; color: #999;">
  <span id="timeDate">载入天数...</span> 
  <span id="times">载入时分秒...</span>
</div>
<script>
  var now = new Date();
  function createtime() {
    var grt = new Date("6/1/2021 00:00:00");
    now.setTime(now.getTime() + 250);
    var days = (now - grt) / 1000 / 60 / 60 / 24;
    var dnum = Math.floor(days);
    var hours = (now - grt) / 1000 / 60 / 60 - (24 * dnum);
    var hnum = Math.floor(hours);
    if(String(hnum).length == 1) { hnum = "0" + hnum; }
    var minutes = (now - grt) / 1000 / 60 - (1440 * dnum) - (60 * hnum);
    var mnum = Math.floor(minutes);
    if(String(mnum).length == 1) { mnum = "0" + mnum; }
    var seconds = (now - grt) / 1000 - (86400 * dnum) - (3600 * hnum) - (60 * mnum);
    var snum = Math.round(seconds);
    if(String(snum).length == 1) { snum = "0" + snum; }
    document.getElementById("timeDate").innerHTML = "小站稳定运行了 " + dnum + " 天 ";
    document.getElementById("times").innerHTML = hnum + " 小时 " + mnum + " 分 " + snum + " 秒";
  }
  setInterval("createtime()", 250);
</script>

<!-- 动态标题 -->
<script>
  var titleTime;
  var OriginTitle = document.title;
  document.addEventListener("visibilitychange", function() {
    if (document.hidden) {
      document.title = "(*^▽^*)我藏好了哦~ " + OriginTitle;
      clearTimeout(titleTime);
    } else {
      document.title = "q(≧▽≦q)被你发现啦~ " + OriginTitle;
      titleTime = setTimeout(function() {
        document.title = OriginTitle;
      }, 2000);
    }
  });
</script>

<!-- 【终极版】高性能主题切换器 (零卡顿且支持持久化) -->
<div id="theme-switch" style="position: fixed; bottom: 32px; right: 32px; width: 40px; height: 40px; border-radius: 50%; background: #eee; box-shadow: 0 4px 10px rgba(0,0,0,0.15); cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 20px; z-index: 10000; transition: all 0.3s cubic-bezier(.65,.05,.36,1);">
  🌓
</div>

<script>
  (function() {
    var root = document.documentElement;
    var btn = document.getElementById('theme-switch');
    
    // 初始化主题：读取缓存，若无缓存则读取系统设置
    var stored = localStorage.getItem('user-theme');
    if (!stored) {
      stored = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    }
    
    // 强制赋予初始属性
    root.setAttribute('data-theme', stored);
    updateBtnStyle(stored);

    btn.addEventListener('click', function() {
      // 触感动画效果
      btn.style.transform = 'scale(0.85)';
      setTimeout(() => btn.style.transform = 'scale(1)', 100);
      
      var current = root.getAttribute('data-theme');
      var target = current === 'dark' ? 'light' : 'dark';
      
      root.setAttribute('data-theme', target);
      localStorage.setItem('user-theme', target);
      updateBtnStyle(target);
    });

    function updateBtnStyle(theme) {
      if (theme === 'dark') {
        btn.style.background = '#333';
        btn.style.color = '#fff';
        btn.innerText = '🌙';
      } else {
        btn.style.background = '#eee';
        btn.style.color = '#333';
        btn.innerText = '🌓';
      }
    }
  })();
</script>
